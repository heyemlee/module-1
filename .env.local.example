# Local-only secrets for Round 1 layout image generation.
# Copy this file to .env.local and fill in the values for your local development environment.

# Your OpenAI API key for generating layout images
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_IMAGE_MODEL=gpt-image-2

# Round 1 snapshot persistence (local dev). When set, the repository persists
# projects + snapshots to this JSON file so they survive a server restart.
# Unset (e.g. in tests) the repository falls back to in-memory storage.
ROUND1_DATA_FILE=.data/round1-projects.json

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Initial database seed data
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=secure_password_here
SEED_ADMIN_NAME='Admin User'
SEED_COMPANY_NAME='ABC Cabinet'
