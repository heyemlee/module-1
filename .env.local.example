# Local-only secrets for Round 1 layout image generation.
# Copy this file to .env.local and fill in the values for your local development environment.

# OpenAI API keys for generating layout images. The app tries keys in
# OPENAI_API_KEY_PRIORITY order and falls back to the next key if generation
# fails. The OpenAI chat agent uses the first configured key in the same order.
OPENAI_API_KEY_PRIMARY=your_primary_openai_api_key_here
OPENAI_BASE_URL_PRIMARY=https://your-primary-proxy.example.com/v1
OPENAI_API_KEY_SECONDARY=your_secondary_openai_api_key_here
# OPENAI_BASE_URL_SECONDARY is optional; omit it to use the official OpenAI API.
OPENAI_API_KEY_TERTIARY=your_tertiary_openai_api_key_here
# OPENAI_BASE_URL_TERTIARY is optional; omit it to use the official OpenAI API.
OPENAI_API_KEY_PRIORITY=PRIMARY,SECONDARY,TERTIARY
OPENAI_IMAGE_MODEL=gpt-image-2

# Round 1 snapshot persistence (local dev). When set, the repository persists
# projects + snapshots to this JSON file so they survive a server restart.
# Unset (e.g. in tests) the repository falls back to in-memory storage.
ROUND1_DATA_FILE=.data/round1-projects.json

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Initial database seed data
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=secure_password_here
SEED_ADMIN_NAME='Admin User'
SEED_COMPANY_NAME='ABC Cabinet'
